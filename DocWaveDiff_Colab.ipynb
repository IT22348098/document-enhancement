## 2. Wavelet Transform Function
```python
def wavelet_transform(img):
    coeffs = pywt.wavedec2(img, 'haar', level=2)
    return coeffs
```

## 3. U-Net Architecture
### Build U-Net model
```python
def unet_model(input_shape=(256, 256, 1)):
    inputs = layers.Input(shape=input_shape)
    # Encoder
    c1 = layers.Convolution2D(32, (3, 3), activation='relu', padding='same')(inputs)
    p1 = layers.MaxPooling2D((2, 2))(c1)
    c2 = layers.Convolution2D(64, (3, 3), activation='relu', padding='same')(p1)
    p2 = layers.MaxPooling2D((2, 2))(c2)
    # Bottleneck
    bottleneck = layers.Convolution2D(128, (3, 3), activation='relu', padding='same')(p2)
    # Decoder
    u1 = layers.Concatenate()([layers.UpSampling2D((2, 2))(bottleneck), c2])
    c3 = layers.Convolution2D(64, (3, 3), activation='relu', padding='same')(u1)
    u2 = layers.Concatenate()([layers.UpSampling2D((2, 2))(c3), c1])
    outputs = layers.Convolution2D(1, (1, 1), activation='sigmoid')(u2)
    return models.Model(inputs=[inputs], outputs=[outputs])
```

